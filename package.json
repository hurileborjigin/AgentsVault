{
  "name": "agents-vault",
  "private": false,
  "version": "1.0.1",
  "description": "Agents Vault — CLI-first retrieval system for coding agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agents-vault/agents-vault.git"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22.5.0"
  },
  "bin": {
    "agents-vault": "bin/agents-vault.js"
  },
  "files": [
    "bin"
  ],
  "scripts": {
    "build": "turbo build",
    "bundle": "turbo build && node scripts/bundle.mjs",
    "dev": "pnpm --filter @agents-vault/cli dev",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "lint": "turbo lint"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "esbuild": "^0.27.4",
    "turbo": "^2.5.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
