{
  "name": "agent-vault-workspace",
  "private": true,
  "version": "1.0.0",
  "description": "Agent Vault — CLI-first retrieval system for coding agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agent-vault/agent-vault.git"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @agent-vault/cli dev",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "ci:typecheck": "pnpm typecheck",
    "ci:test": "pnpm test",
    "ci:lint": "pnpm lint"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
