{
  "name": "agents-vault",
  "private": false,
  "version": "1.0.5",
  "description": "Agents Vault — CLI-first retrieval system for coding agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hurileborjigin/AgentsVault.git"
  },
  "homepage": "https://github.com/hurileborjigin/AgentsVault",
  "keywords": [
    "rag",
